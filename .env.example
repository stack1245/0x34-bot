# Discord Developer Portal에서 발급받은 봇 토큰입니다.
DISCORD_TOKEN=replace-with-your-discord-bot-token

# 테스트 서버 ID를 넣으면 Slash Command가 해당 서버에만 빠르게 동기화됩니다.
# 이 모드에서는 같은 서버에 중복으로 뜨지 않도록 기존 전역 커맨드를 먼저 비웁니다.
# 비워두면 전역 커맨드로 동기화되어 Discord 반영까지 시간이 걸릴 수 있습니다.
GUILD_ID=

# SQLite 파일 위치입니다. Railway에서는 Volume 경로(예: /app/data/bot.db)를 DB_PATH에 넣으세요.
# DATABASE_PATH도 하위 호환으로 지원하지만, 둘 다 있으면 DB_PATH가 우선합니다.
DB_PATH=data/bot.db
# DATABASE_PATH=data/bot.db

# 한국 팀 운영 기준 기본 시간대입니다.
TIMEZONE=Asia/Seoul

# 알림을 보낼 채널 ID입니다. 비워두면 명령어가 실행된 채널을 사용합니다.
SCHEDULE_CHANNEL_ID=
TOURNAMENT_CHANNEL_ID=
RECRUITMENT_CHANNEL_ID=

# Google AI Studio에서 발급받은 Gemini API 키입니다.
# /*생성 커맨드가 Gemini로 모집 글을 만들 때 사용합니다.
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# true면 /일정추가 시 Discord 서버 이벤트도 같이 만들려고 시도합니다.
# 봇에게 "이벤트 관리" 권한이 필요합니다.
ENABLE_SERVER_EVENTS=true

# true면 봇 시작 시 Slash Command를 Discord에 동기화합니다.
SYNC_COMMANDS=true

# true면 봇 시작 시 현재 동기화 대상의 기존 Slash Command도 먼저 비운 뒤 현재 코드 명령만 다시 동기화합니다.
# GUILD_ID가 설정된 경우 전역 커맨드는 중복 방지를 위해 이 값과 무관하게 먼저 비워집니다.
CLEAR_COMMANDS_ON_START=false

# true면 봇 소유자만 쓸 수 있는 `!인증 sync`, `!인증 clear` 텍스트 명령을 켭니다.
# 이 기능을 쓰려면 Discord Developer Portal의 Message Content Intent도 활성화해야 합니다.
ENABLE_ADMIN_TEXT_COMMANDS=false
